# ── Server ──────────────────────────────────────
SERVER_PORT=8080
SERVER_ENVIRONMENT=development

# ── Auth Service ────────────────────────────────
SERVICES_AUTH_ADDR=localhost:9091

# ── Redis ───────────────────────────────────────
REDIS_ADDRESS=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ─────────────────────────────────────────
JWT_ACCESS_SECRET=

# ── Rate Limiting ──────────────────────────────
RATE_LIMITING_ENABLED=true
RATE_LIMITING_MAX_REQUESTS=100
RATE_LIMITING_WINDOW_SECONDS=60

# ── CORS ────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:3000

# ── Tracing ─────────────────────────────────────
TRACING_ENABLED=false
TRACING_COLLECTOR_URL=localhost:4317

# ── Environment ─────────────────────────────────
ENVIRONMENT=dev
