# ── Server ──────────────────────────────────────
HTTP_PORT=8081
GRPC_PORT=9091

# ── Database ────────────────────────────────────
POSTGRES_USER=auth_user
POSTGRES_PASSWORD= 
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=moneymate
# ── Redis ───────────────────────────────────────
